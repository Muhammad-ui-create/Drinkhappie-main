{%- liquid
  assign og_title = page_title | default: shop.name
  assign og_url = canonical_url | default: request.origin
  assign og_type = 'website'
  assign og_description = page_description | default: shop.description | default: shop.name

  if request.page_type == 'product'
    assign og_type = 'product'
    assign og_description = product.title | append: ' — premium hemp-derived THC seltzer by Happie®. Nano-emulsified for fast onset, 30 calories, vegan. Shop online with free shipping.'
  elsif request.page_type == 'article'
    assign og_type = 'article'
    assign og_description = article.excerpt_or_content | strip_html | truncate: 155
    assign og_title = article.title | append: ' | Happie Blog'
  elsif request.page_type == 'password'
    assign og_url = request.origin
  elsif request.page_type == 'collection'
    if collection.handle == 'thc-drinks' or collection.handle == 'thc'
      assign og_description = 'Shop the best Delta-9 THC seltzers online. 7 flavors, 5mg & 10mg, nano-emulsified. Zero alcohol, 30 calories. Better than Brez, Cann, Wynk.'
    elsif collection.handle == 'fungi-fusion' or collection.handle == 'fungi'
      assign og_description = 'Fungi Fusion sparkling mushroom drinks — made with Lion''s Mane, Cordyceps and Red Reishi. Caffeine-free, alcohol-free, 40 calories.'
    endif
  endif

  # Homepage: explicit OG title to prevent admin truncation. Keep ≤ 60 chars.
  if request.page_type == 'index'
    assign og_title = 'Happie® | Best THC Seltzers & Mushroom Drinks Online'
    assign og_description = 'Premium hemp-derived THC seltzers (5mg/10mg) and Fungi Fusion mushroom drinks. Nano-emulsified, fast-acting, zero alcohol. Subscribe & save 20%. Ships to 40+ states.'
  endif
%}

<meta property="og:site_name" content="{{ shop.name }}">
<meta property="og:url" content="{{ og_url }}">
<meta property="og:title" content="{{ og_title | escape }}">
<meta property="og:type" content="{{ og_type }}">
<meta property="og:description" content="{{ og_description | escape }}">

{%- if page_image -%}
  <meta property="og:image" content="https:{{ page_image | image_url }}">
  <meta
    property="og:image:secure_url"
    content="https:{{ page_image | image_url }}"
  >
  <meta property="og:image:width" content="{{ page_image.width }}">
  <meta property="og:image:height" content="{{ page_image.height }}">
{%- else -%}
  <meta property="og:image" content="{{ 'logo_svg.png' | file_url }}">
{%- endif -%}

{%- comment -%} GEO: article-specific OG meta for richer LinkedIn/Facebook link previews {%- endcomment -%}
{%- if request.page_type == 'article' -%}
  <meta property="article:published_time" content="{{ article.published_at | date: '%Y-%m-%dT%H:%M:%S%z' }}">
  <meta property="article:modified_time" content="{{ article.updated_at | default: article.published_at | date: '%Y-%m-%dT%H:%M:%S%z' }}">
  <meta property="article:author" content="{{ article.author }}">
  <meta property="article:section" content="{{ blog.title }}">
  {%- for tag in article.tags -%}
  <meta property="article:tag" content="{{ tag }}">
  {%- endfor -%}
{%- endif -%}

{%- if request.page_type == 'product' -%}
  <meta
    property="og:price:amount"
    content="{{ product.price | money_without_currency | strip_html }}"
  >
  <meta property="og:price:currency" content="{{ cart.currency.iso_code }}">
{%- endif -%}

{%- if settings.social_twitter_link != blank -%}
  <meta
    name="twitter:site"
    content="{{ settings.social_twitter_link | split: 'twitter.com/' | last | prepend: '@' }}"
  >
{%- endif -%}
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="{{ og_title | escape }}">
<meta name="twitter:description" content="{{ og_description | escape }}">
{% if page_image %}
  <meta name="twitter:image" content="https:{{ page_image | image_url: width: 1200 }}">
{% else %}
  <meta name="twitter:image" content="{{ 'logo_svg.png' | file_url }}">
{% endif %}
