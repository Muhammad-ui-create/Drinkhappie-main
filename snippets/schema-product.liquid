{%- comment -%}
  Product JSON-LD — Happie®
  Include from sections/main-product.liquid (or the product template), once per product page.
  Usage:  {%- render 'schema-product', product: product -%}

  NO review / aggregateRating output (per SEO decision — Amazon reviews are not
  first-party and would violate Google's review-snippet policy). Add aggregateRating
  ONLY after on-site reviews are collected via a Shopify reviews app.

  IMPORTANT: Before deploying, confirm the theme is not ALREADY emitting Product
  schema (Shrine/Dawn-based themes sometimes do). If it is, replace that block with
  this one rather than adding a second — duplicate Product schema can suppress rich results.
{%- endcomment -%}
{%- assign current_variant = product.selected_or_first_available_variant -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Product",
  "name": {{ product.title | json }},
  "image": [
    {%- for image in product.images limit: 5 -%}
      "https:{{ image | image_url: width: 1200 }}"{%- unless forloop.last -%},{%- endunless -%}
    {%- endfor -%}
  ],
  "description": {{ product.description | strip_html | truncatewords: 60 | json }},
  "sku": {{ current_variant.sku | json }},
  "brand": {
    "@type": "Brand",
    "name": "Happie"
  },
  "offers": {
    "@type": "Offer",
    "url": "{{ shop.url }}{{ product.url }}",
    "priceCurrency": "{{ cart.currency.iso_code }}",
    "price": "{{ current_variant.price | money_without_currency | strip_html }}",
    "availability": "{% if current_variant.available %}https://schema.org/InStock{% else %}https://schema.org/OutOfStock{% endif %}",
    "itemCondition": "https://schema.org/NewCondition"
  }
}
</script>
