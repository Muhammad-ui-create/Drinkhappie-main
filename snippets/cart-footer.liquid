<data-island
  x-data="CartFooter"
  data-cart-footer
  on="idle"
>
  {% if cart != empty %}
    <div class="border-t-section border-scheme-text {% if template == 'cart' %}pt-5 lg:pt-10{% else %} pt-2.5 lg:pt-5 {% endif %}">
      <div class="grid grid-cols-14 gap-2  {% if template == 'cart' %} max-w-5xl mx-auto {% endif %}">
        {% if template == 'cart' and settings.cart_notes_enable %}
          <div class="col-span-14 md:col-span-6 md:row-span-3">
            <label class="block text-sm" for="CartSpecialInstructions">
              {{- 'cart.general.note' | t -}}
            </label>
            <data-island class="contents" x-data="CartNote">
              <textarea
                name="note"
                id="CartSpecialInstructions"
                class="input mb-2 mt-2.5 block w-full p-2 transition-opacity"
                :class="{ 'opacity-50 cursor-progress' : updating }"
                :readonly="updating"
                @change="updateNote"
                @keyup.debounce.750ms="$dispatch('change')"
              >
                {{- cart.note -}}
              </textarea>
            </data-island>
          </div>
        {% endif %}
        <div class="col-span-14 {% if template == 'cart' %} md:col-span-6 md:col-end-last {% endif %}">
          <dl class="grid grid-cols-2 {% if template == 'cart' %} md:grid-cols-5 {% endif %} items-center text-right">
            {%- for discount_application in cart.cart_level_discount_applications -%}
              <div class="col-span-full -mx-1 inline-block flex justify-between rounded-button bg-scheme-accent-1 p-1 text-scheme-accent-1-contrast lg:col-span-full lg:col-start-2">
                <dt class=" {% if template == 'cart' %} md:col-span-3 {% endif %}">
                  <span class="sr-only">
                    {{- 'customer.order.discount' | t }}:</span
                  ><span>{{- discount_application.title -}}</span>
                </dt>
                <dd class="{% if template == 'cart' %} md:col-span-2 {% endif %}">
                  -{{ discount_application.total_allocated_amount | money }}
                </dd>
              </div>
            {%- endfor -%}
            <dt class="text-left {% if template == 'cart' %} md:col-span-3 {% endif %}">
              {{ 'cart.general.subtotal' | t }}
            </dt>
            <dd class="{% if template == 'cart' %} md:col-span-2 {% endif %}">
              {{ cart.total_price | money_with_currency }}
            </dd>
          </dl>
          <p class="mt-2.5 text-right text-xs">
            {%- if cart.taxes_included -%}
              {{ 'cart.general.taxes_included_but_shipping_at_checkout' | t }}
            {%- else -%}
              {{ 'cart.general.shipping_at_checkout' | t }}
            {%- endif -%}
          </p>
        </div>
        <div class="col-span-14 row-start-3 {% if template == 'cart' %} md:row-start-2 md:col-span-6 md:col-end-last {% endif %}">
          <div class="relative z-10">
            <input
              class="no-js ml-auto block cursor-pointer border-general border-scheme-text px-5 py-2.5"
              type="submit"
              name="update"
              value="{{ 'cart.general.update' | t }}"
              form="cart"
            >
            <div class="push-btn relative inline-block w-full {% if template == 'cart' %} lg:mt-2.5 {% endif %}">
              <input
                class="push-btn__surface ml-auto block w-full cursor-pointer"
                type="submit"
                name="checkout"
                value="{{ 'cart.general.checkout' | t }}"
                form="cart"
              >
            </div>
          </div>

          {%- if additional_checkout_buttons
            and template == 'cart'
            and settings.enable_accelerated_checkout
          -%}
            <script>
              const submitBtnEl = document.querySelector(
                'input[type="submit"][name="checkout"][form="cart"]'
              );

              if (submitBtnEl) {
                document.documentElement.style.setProperty(
                  '--checkout-button-height',
                  `${submitBtnEl.getBoundingClientRect().height}px`
                );
              }
            </script>
            <div class="cart__dynamic-checkout-buttons additional-checkout-buttons mt-2.5 lg:mt-5">
              {{ content_for_additional_checkout_buttons }}
            </div>
          {%- endif -%}
        </div>
      </div>
      {%- comment -%} Bundle upsell (drawer only): featured bundle with savings vs compare-at price. Hidden when already in cart. {%- endcomment -%}
      {%- if template != 'cart' -%}
        {%- liquid
          assign hb_up = all_products['cherry-citrus-kickoff']
          assign hb_in_cart = false
          for item in cart.items
            if item.product.handle == hb_up.handle
              assign hb_in_cart = true
            endif
          endfor
        -%}
        {%- if hb_up.id != blank and hb_up.available and hb_in_cart == false -%}
          {%- liquid
            assign hb_v = hb_up.selected_or_first_available_variant
            assign hb_save_pct = 0
            if hb_v.compare_at_price > hb_v.price
              assign hb_diff = hb_v.compare_at_price | minus: hb_v.price
              assign hb_save_pct = hb_diff | times: 100.0 | divided_by: hb_v.compare_at_price | round
            endif
          -%}
          <div class="hb-cart-upsell">
            <div class="hb-cart-upsell__label">🎁 Complete your order &amp; save</div>
            <div class="hb-cart-upsell__row">
              <a href="{{ hb_up.url }}" class="hb-cart-upsell__media">
                <img src="{{ hb_up.featured_image | image_url: width: 140 }}" alt="{{ hb_up.title | escape }}" width="70" height="70" loading="lazy">
              </a>
              <div class="hb-cart-upsell__info">
                <a href="{{ hb_up.url }}" class="hb-cart-upsell__title">{{ hb_up.title }}</a>
                <div class="hb-cart-upsell__prices">
                  <span class="hb-cart-upsell__price">{{ hb_v.price | money }}</span>
                  {%- if hb_save_pct > 0 -%}
                    <s class="hb-cart-upsell__compare">{{ hb_v.compare_at_price | money }}</s>
                    <span class="hb-cart-upsell__save">Save {{ hb_save_pct }}%</span>
                  {%- endif -%}
                </div>
              </div>
              <button type="button" class="hb-cart-upsell__add" data-upsell-variant="{{ hb_v.id }}">Add</button>
            </div>
          </div>
          <script>
            (function () {
              document.addEventListener('click', function (e) {
                var btn = e.target.closest('.hb-cart-upsell__add');
                if (!btn || btn.disabled) return;
                btn.disabled = true;
                btn.textContent = '...';
                var fd = new FormData();
                fd.append('id', btn.getAttribute('data-upsell-variant'));
                fd.append('quantity', '1');
                fetch('/cart/add.js', { method: 'POST', body: fd, headers: { 'X-Requested-With': 'XMLHttpRequest' } })
                  .then(function (r) { return r.json(); })
                  .then(function () {
                    document.body.dispatchEvent(new CustomEvent('shapes:cart:afteradditem', { bubbles: true }));
                  })
                  .catch(function () { btn.disabled = false; btn.textContent = 'Add'; });
              });
            })();
          </script>
        {%- endif -%}
      {%- endif -%}

      <div class="hb-cart-payments" aria-label="Accepted payment methods">
        {%- assign hb_pay_allow = 'visa,master,american_express,paypal,apple_pay,shopify_pay,google_pay' | split: ',' -%}
        {%- for allowed in hb_pay_allow -%}
          {%- if shop.enabled_payment_types contains allowed -%}
            {{ allowed | payment_type_svg_tag: class: 'hb-cart-payment-icon' }}
          {%- endif -%}
        {%- endfor -%}
      </div>
      <style>
        .hb-cart-upsell{margin-top:10px;border:1.5px dashed #C9A0BD;border-radius:12px;padding:8px 11px;background:#FDF8FB;}
        .hb-cart-upsell__label{font-size:10.5px;font-weight:700;letter-spacing:.05em;text-transform:uppercase;color:#962F80;margin-bottom:5px;}
        .hb-cart-upsell__row{display:flex;align-items:center;gap:10px;}
        .hb-cart-upsell__media img{width:42px;height:42px;object-fit:contain;border-radius:8px;background:#fff;display:block;}
        .hb-cart-upsell__info{flex:1;min-width:0;}
        .hb-cart-upsell__title{font-size:13px;font-weight:700;text-decoration:none;color:inherit;display:block;line-height:1.25;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
        .hb-cart-upsell__prices{display:flex;align-items:center;gap:6px;margin-top:2px;flex-wrap:wrap;}
        .hb-cart-upsell__price{font-weight:800;font-size:13px;}
        .hb-cart-upsell__compare{font-size:11.5px;opacity:.55;}
        .hb-cart-upsell__save{font-size:10.5px;font-weight:700;color:#2e8b6f;background:#E7F6EF;padding:2px 7px;border-radius:999px;}
        .hb-cart-upsell__add{flex:none;background:#962F80;color:#fff;border:0;border-radius:999px;font-weight:700;font-size:12.5px;padding:8px 15px;cursor:pointer;}
        .hb-cart-upsell__add:hover{background:#7C2568;}
        .hb-cart-upsell__add:disabled{opacity:.6;cursor:default;}
        .hb-cart-payments{display:flex;flex-wrap:nowrap;gap:5px;align-items:center;justify-content:center;margin-top:9px;opacity:.9;}
        .hb-cart-payment-icon{height:20px;width:auto;border-radius:3px;flex:none;}
        @media (max-width:380px){.hb-cart-payment-icon{height:17px;}}
      </style>

      <div
        class="mt-5 inline-block rounded-button bg-scheme-accent-1 p-2.5 text-sm text-scheme-accent-1-contrast empty:hidden"
        id="cart-errors"
      ></div>
    </div>
  {% endif %}
</data-island>
