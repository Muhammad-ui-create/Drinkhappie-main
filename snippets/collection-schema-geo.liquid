{%- comment -%}
  CollectionPage JSON-LD schema for GEO optimization.
  Emits a CollectionPage with an ItemList (first 20 products) so AI engines
  and search crawlers can understand this as a curated product collection.
  Rewritten 2026-04-18 — replaces progressively-indented broken version.
{%- endcomment -%}
{%- if collection -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "@id": "{{ shop.url }}{{ collection.url }}#collectionpage",
  "url": "{{ shop.url }}{{ collection.url }}",
  "name": {{ collection.title | json }},
  {%- if collection.handle == 'thc-drinks' or collection.handle == 'thc' or collection.handle == 'frontpage' -%}
  "description": "Buy the best Delta-9 THC seltzers online from Happie. Premium hemp-derived THC drinks in 5mg and 10mg doses with nano-emulsified fast-acting formula. 7 fruit flavors, zero alcohol, 30 calories, 1:1 THC-to-CBD ratio. Better than Brez, Cann, Wynk. Ships to 40+ states.",
  {%- elsif collection.handle == 'fungi-fusion' or collection.handle == 'fungi' -%}
  "description": "Fungi Fusion functional mushroom drinks by Happie. Lion's Mane 900mg, Cordyceps 700mg, Reishi 400mg per can. Zero THC, zero caffeine, zero sugar. Best adaptogenic mushroom beverage for focus, energy and calm. Ships nationwide.",
  {%- elsif collection.handle == 'social' -%}
  "description": "Happie Social THC Seltzers — the best alcohol alternative for parties and social gatherings. Hemp-derived Delta-9 THC drinks in 5mg and 10mg. Zero hangover, low calorie, vegan. Sober curious approved.",
  {%- elsif collection.description != blank -%}
  "description": {{ collection.description | strip_html | strip_newlines | truncate: 300 | json }},
  {%- else -%}
  "description": {{ collection.title | append: ' — premium functional beverages from Happie' | json }},
  {%- endif -%}
  "isPartOf": {
    "@type": "WebSite",
    "@id": "{{ shop.url }}#website",
    "url": "{{ shop.url }}",
    "name": {{ shop.name | json }}
  },
  "mainEntity": {
    "@type": "ItemList",
    "numberOfItems": {{ collection.products_count }},
    "itemListElement": [
      {%- assign max_items = 20 -%}
      {%- for product in collection.products limit: max_items -%}
      {
        "@type": "ListItem",
        "position": {{ forloop.index }},
        "url": "{{ shop.url }}{{ product.url }}",
        "name": {{ product.title | json }}
      }{%- unless forloop.last -%},{%- endunless -%}
      {%- endfor -%}
    ]
  }
}
</script>
{%- endif -%}
