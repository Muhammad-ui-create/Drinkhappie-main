{%- liquid
  assign submit_label = section.settings.submit_button_label
  if submit_label == blank
    assign submit_label = 'contact.form.send' | t
  endif
  assign hpcu_title = page.title
  if section.settings.heading_override != blank
    assign hpcu_title = section.settings.heading_override
  endif
  assign hpcu_bg = section.settings.section_background_color
  assign hpcu_wave = section.settings.wave_bottom_color | default: '#962f80'
  assign hpcu_wave_key = hpcu_wave | downcase | strip
  if template.suffix == 'contact-updated'
    if hpcu_wave_key == '#ffffff' or hpcu_wave_key == '#fff' or hpcu_wave_key == 'rgb(255, 255, 255)' or hpcu_wave_key == 'rgba(255, 255, 255, 1)' or hpcu_wave_key == 'rgba(255,255,255,1)'
      assign hpcu_wave = '#962f80'
    endif
  endif
-%}
<section
  class="hpcu-section relative overflow-hidden text-scheme-text {% if section.settings.use_custom_background == false %}{% if section.settings.use_gradient_background %}bg-scheme-gradient {% endif %}bg-scheme-background{% endif %}"
  data-color-scheme="{{ section.settings.color_scheme }}"
  {% if section.settings.use_custom_background %}
    style="background-color: {{ hpcu_bg }};"
  {% endif %}
>
  <style>
    #shopify-section-{{ section.id }} .hpcu-inner {
      position: relative;
      z-index: 2;
      margin-left: auto;
      margin-right: auto;
      padding-top: clamp(2.25rem, 5vw, 3.75rem);
      padding-bottom: calc(clamp(3rem, 7vw, 4.5rem) + clamp(36px, 6vw, 56px));
      width: 100%;
      max-width: min(1080px, 100%);
    }
    #shopify-section-{{ section.id }} .hpcu-grid {
      display: grid;
      gap: clamp(1.75rem, 4vw, 2.75rem);
      align-items: start;
    }
    @media (min-width: 1024px) {
      #shopify-section-{{ section.id }} .hpcu-grid {
        grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
        gap: clamp(2rem, 4vw, 3.25rem);
      }
    }
    #shopify-section-{{ section.id }} .hpcu-intro-title {
      font-family: 'Poppins', sans-serif;
      font-size: clamp(1.85rem, 4.2vw, 2.65rem);
      font-weight: 700;
      line-height: 1.12;
      color: #3d3d3d;
      margin: 0 0 1.1rem;
      text-align: left;
      letter-spacing: -0.02em;
    }
    #shopify-section-{{ section.id }} .hpcu-intro .rte,
    #shopify-section-{{ section.id }} .hpcu-intro .hpcu-default-copy {
      font-family: 'Poppins', sans-serif;
      font-size: 0.9375rem;
      line-height: 1.65;
      color: #4a4a4a;
    }
    #shopify-section-{{ section.id }} .hpcu-intro .rte p,
    #shopify-section-{{ section.id }} .hpcu-default-copy p {
      margin: 0 0 0.85em;
    }
    #shopify-section-{{ section.id }} .hpcu-intro .rte p:last-child,
    #shopify-section-{{ section.id }} .hpcu-default-copy p:last-child {
      margin-bottom: 0;
    }
    #shopify-section-{{ section.id }} .hpcu-contact-rows {
      list-style: none;
      margin: 1.25rem 0 0;
      padding: 0;
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }
    #shopify-section-{{ section.id }} .hpcu-contact-row {
      display: flex;
      align-items: flex-start;
      gap: 0.75rem;
    }
    #shopify-section-{{ section.id }} .hpcu-contact-row__icon {
      flex-shrink: 0;
      width: 1.35rem;
      height: 1.35rem;
      margin-top: 0.15rem;
      color: #50b2bd;
    }
    #shopify-section-{{ section.id }} .hpcu-contact-row__icon svg {
      width: 100%;
      height: 100%;
      display: block;
    }
    #shopify-section-{{ section.id }} .hpcu-contact-row__body {
      font-size: 0.9375rem;
      line-height: 1.5;
      color: #4a4a4a;
    }
    #shopify-section-{{ section.id }} .hpcu-contact-row__label {
      display: block;
      font-weight: 700;
      color: #3d3d3d;
      margin-bottom: 0.15rem;
    }
    #shopify-section-{{ section.id }} .hpcu-contact-row__body a {
      color: #3d3d3d;
      text-decoration: none;
      border-bottom: 1px solid rgba(80, 178, 189, 0.45);
      transition: color 0.2s ease, border-color 0.2s ease;
    }
    #shopify-section-{{ section.id }} .hpcu-contact-row__body a:hover {
      color: #50b2bd;
      border-bottom-color: #50b2bd;
    }
    #shopify-section-{{ section.id }} .hpcu-form-card {
      background: #ffffff;
      border-radius: 20px;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
      padding: clamp(1.35rem, 3vw, 1.85rem) clamp(1.25rem, 3vw, 2rem) clamp(1.5rem, 3vw, 2rem);
    }
    #shopify-section-{{ section.id }} .hpcu-label {
      display: block;
      margin-top: 0.875rem;
      margin-bottom: 0.35rem;
      font-family: 'Poppins', sans-serif;
      font-size: 0.6875rem;
      font-weight: 600;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: #666666;
    }
    #shopify-section-{{ section.id }} .hpcu-row-2 .hpcu-label {
      margin-top: 0;
    }
    #shopify-section-{{ section.id }} .hpcu-input,
    #shopify-section-{{ section.id }} .hpcu-textarea {
      width: 100%;
      font-family: 'Poppins', sans-serif;
      font-size: 0.9375rem;
      line-height: 1.4;
      color: #1a1a1a;
      background: #ffffff;
      border: 1px solid #e0e0e0;
      border-radius: 999px;
      padding: 0.62rem 1.15rem;
      outline: none;
      transition: border-color 0.2s ease, box-shadow 0.2s ease;
    }
    #shopify-section-{{ section.id }} .hpcu-textarea {
      border-radius: 18px;
      min-height: 8.5rem;
      resize: vertical;
    }
    #shopify-section-{{ section.id }} .hpcu-input::placeholder,
    #shopify-section-{{ section.id }} .hpcu-textarea::placeholder {
      color: #a3a3a3;
    }
    #shopify-section-{{ section.id }} .hpcu-input:focus,
    #shopify-section-{{ section.id }} .hpcu-textarea:focus {
      border-color: #50b2bd;
      box-shadow: 0 0 0 3px rgba(80, 178, 189, 0.2);
    }
    #shopify-section-{{ section.id }} .hpcu-row-2 {
      display: grid;
      gap: 0.75rem;
    }
    @media (min-width: 640px) {
      #shopify-section-{{ section.id }} .hpcu-row-2 {
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
      }
    }
    #shopify-section-{{ section.id }} .hpcu-submit-wrap {
      margin-top: 1.25rem;
    }
    #shopify-section-{{ section.id }} .hpcu-submit {
      width: 100%;
      cursor: pointer;
      font-family: 'Poppins', sans-serif;
      font-size: 0.75rem;
      font-weight: 600;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: #ffffff;
      background: #50b2bd;
      border: none;
      border-radius: 999px;
      padding: 0.95rem 1.5rem;
      transition: background 0.2s ease, transform 0.15s ease;
    }
    #shopify-section-{{ section.id }} .hpcu-submit:hover {
      background: #449aa4;
    }
    #shopify-section-{{ section.id }} .hpcu-submit:active {
      transform: scale(0.99);
    }
    #shopify-section-{{ section.id }} .form-success {
      font-family: 'Poppins', sans-serif;
      font-size: 0.9375rem;
      color: #2d6a4f;
      margin: 0;
    }
    #shopify-section-{{ section.id }} .hpcu-wave {
      position: absolute;
      left: 0;
      right: 0;
      bottom: 0;
      z-index: 1;
      line-height: 0;
    }
    #shopify-section-{{ section.id }} .hpcu-wave svg {
      display: block;
      width: 100%;
      height: clamp(44px, 8vw, 72px);
    }
    {%- if template.suffix == 'contact-updated' -%}
    body.template-page-contact-updated #MainContent {
      margin-bottom: 0;
    }
    body.template-page-contact-updated #shopify-section-{{ section.id }} {
      margin-bottom: 0 !important;
    }
    body.template-page-contact-updated #shopify-section-{{ section.id }} .hpcu-section {
      margin-bottom: 0;
      padding-bottom: 0;
      box-shadow: 0 48px 0 0 {{ hpcu_wave }};
    }
    body.template-page-contact-updated footer.section-footer {
      margin-top: 0 !important;
    }
    body.template-page-contact-updated main + .shopify-section-group-footer-group {
      margin-top: -24px !important;
      position: relative;
      z-index: 1;
    }
    body.template-page-contact-updated main + * {
      margin-top: 0 !important;
    }
    body.template-page-contact-updated #shopify-section-{{ section.id }} .hpcu-wave svg {
      transform: translateY(3px);
    }
    {%- endif -%}
  </style>

  <div class="hpcu-inner px-section mx-auto w-full max-w-site">
    <div class="hpcu-grid">
      <div class="hpcu-intro">
        <h1 class="hpcu-intro-title break-words {{ settings.heading_drop_shadow_style }}">
          {{ hpcu_title | escape }}
        </h1>
        {%- if page.content != blank -%}
          <data-island x-data="RTE" class="rte">
            {{ page.content }}
          </data-island>
        {%- elsif section.settings.intro_richtext != blank -%}
          <div class="rte">
            {{ section.settings.intro_richtext }}
          </div>
        {%- else -%}
          <div class="hpcu-default-copy">
            <p>
              Got a question? We’re here for you. Whether you’re new to Happie or a long-time fan, our team is happy to help with anything from product details and order support to partnership opportunities and media inquiries. We typically respond within 24–48 hours, Monday through Friday. For anything urgent, don’t hesitate to give us a call.
            </p>
            <ul class="hpcu-contact-rows" role="list">
              <li class="hpcu-contact-row">
                <span class="hpcu-contact-row__icon" aria-hidden="true">
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                  </svg>
                </span>
                <div class="hpcu-contact-row__body">
                  <span class="hpcu-contact-row__label">Phone</span>
                  <a href="tel:+14632189646">(463) 218-9646</a>
                </div>
              </li>
              <li class="hpcu-contact-row">
                <span class="hpcu-contact-row__icon" aria-hidden="true">
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                  </svg>
                </span>
                <div class="hpcu-contact-row__body">
                  <span class="hpcu-contact-row__label">Email</span>
                  <a href="mailto:orders@drinkhappie.com">orders@drinkhappie.com</a>
                </div>
              </li>
            </ul>
          </div>
        {%- endif -%}
      </div>

      <div class="hpcu-form-card">
        {%- assign form_id = 'ContactFormUpdated' -%}
        {% form 'contact', id: form_id, class: 'hpcu-form outline-none' %}
          {% if form.posted_successfully? %}
            <p class="form-success">
              {{ 'contact.form.post_success' | t }}
            </p>
          {% else %}
            {{ form.errors | default_errors }}
            <div class="hpcu-row-2">
              <div class="hpcu-label-row">
                <label class="hpcu-label" for="ContactFormUpdatedName">
                  {{- 'contact.form.name' | t -}}
                </label>
                <input
                  type="text"
                  class="hpcu-input"
                  name="contact[name]"
                  id="ContactFormUpdatedName"
                  value="{% if form.name %}{{ form.name }}{% elsif customer %}{{ customer.name }}{% endif %}"
                  required
                  aria-required="true"
                  autocomplete="name"
                >
              </div>
              <div class="hpcu-label-row">
                <label class="hpcu-label" for="ContactFormUpdatedEmail">
                  {{- 'contact.form.email' | t -}}
                </label>
                <input
                  type="email"
                  name="contact[email]"
                  id="ContactFormUpdatedEmail"
                  class="hpcu-input {% if form.errors contains 'email' %}border-theme-color{% endif %}"
                  value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}"
                  spellcheck="false"
                  autocomplete="email"
                  autocapitalize="off"
                  required
                  aria-required="true"
                >
              </div>
            </div>

            <label class="hpcu-label" for="ContactFormUpdatedPhone">
              {{- 'contact.form.phone' | t -}}
            </label>
            <input
              type="tel"
              name="contact[phone]"
              id="ContactFormUpdatedPhone"
              class="hpcu-input"
              value="{% if form.phone %}{{ form.phone }}{% elsif customer %}{{ customer.phone }}{% endif %}"
              pattern="[0-9\-]*"
              autocomplete="tel"
            >

            <label class="hpcu-label" for="ContactFormUpdatedMessage">
              {{- 'contact.form.message' | t -}}
            </label>
            <textarea
              name="contact[body]"
              id="ContactFormUpdatedMessage"
              required
              aria-required="true"
              class="hpcu-textarea"
              rows="6"
            >
              {%- if form.body -%}
                {{- form.body -}}
              {%- endif -%}
            </textarea>

            <div class="hpcu-submit-wrap">
              <input type="submit" class="hpcu-submit" value="{{ submit_label | escape }}">
            </div>
          {% endif %}
        {% endform %}
      </div>
    </div>
  </div>

  <div class="hpcu-wave" aria-hidden="true">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1440 72" preserveAspectRatio="none" focusable="false">
      <path fill="{{ hpcu_wave }}" d="M0,0v18c120,28 240,8 360,22s240,32 360,18 240,-28 360,-14 180,22 360,10v18H0z"/>
    </svg>
  </div>
</section>

{% schema %}
{
  "name": "Contact page updated",
  "tag": "section",
  "class": "main-page-contact-updated-section",
  "settings": [
    {
      "type": "paragraph",
      "content": "Peach band, two columns, and a curved transition into the footer color (default purple). On the contact-updated template, white wave is treated as footer purple. Built-in copy + phone/email show when the page body in Admin is empty; otherwise the page content is used."
    },
    {
      "type": "text",
      "id": "heading_override",
      "label": "Heading override",
      "info": "Leave blank to use the page title (e.g. Contact Us)."
    },
    {
      "type": "richtext",
      "id": "intro_richtext",
      "label": "Intro copy (optional)",
      "info": "Used only when the page body is empty. Otherwise edit the page in Admin."
    },
    {
      "type": "checkbox",
      "id": "use_custom_background",
      "label": "Use custom peach background",
      "default": true
    },
    {
      "type": "color",
      "id": "section_background_color",
      "label": "Section background",
      "default": "#fde5c3"
    },
    {
      "type": "color",
      "id": "wave_bottom_color",
      "label": "Wave fill (match footer / section below)",
      "default": "#962f80"
    },
    {
      "type": "text",
      "id": "submit_button_label",
      "label": "Submit button label",
      "default": "Send message",
      "info": "Leave blank to use the theme translation."
    },
    {
      "type": "header",
      "content": "t:common.settings.header_color"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "default": "scheme1",
      "label": "t:common.settings.color_scheme.label"
    },
    {
      "type": "checkbox",
      "id": "use_gradient_background",
      "label": "t:common.settings.use_gradient_background.label",
      "info": "Only applies when custom background is off."
    }
  ]
}
{% endschema %}
