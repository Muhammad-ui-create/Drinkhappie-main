    },
    {
      "type": "textarea",
      "id": "value_4_text",
      "label": "Pillar 4 text",
      "default": "Born from NorCal’s wellness and cannabis culture, now available in retail locations across multiple states and shipping direct nationwide."
    },
    {
      "type": "header",
      "content": "Optional image (no headline)"
    },
    {
      "type": "image_picker",
      "id": "image_editorial",
      "label": "Editorial image between pillars and founder",
      "info": "Optional. Markdown allows discretionary imagery only — no extra copy. Leave blank to hide."
    },
    {
      "type": "header",
      "content": "Section 3 — Founder"
    },
    {
      "type": "text",
      "id": "founder_heading",
      "label": "Section heading",
      "default": "Meet the Founder"
