        { "value": "wave", "label": "Wave" },
        { "value": "wave-smooth", "label": "Wave (smooth)" },
        { "value": "arc", "label": "Arc" },
        { "value": "slope-left", "label": "Slope (left to right)" },
        { "value": "slope-right", "label": "Slope (right to left)" }
