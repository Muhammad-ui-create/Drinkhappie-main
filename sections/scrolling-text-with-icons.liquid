{% liquid
  if section.settings.background_color == 'bg-transparent text-scheme-text' and section.settings.show_border == false
    assign icon_margin = 'mr-1'
  else
    assign icon_margin = 'mr-2'
  endif

  assign icon_size = section.settings.icon_size
  assign gap = section.settings.gap

  capture content
    echo '<div class="flex items-center ' | append: gap | append: '">'
    for block in section.blocks
      render 'scrolling-text-with-icons-block', block: block, icon_margin: icon_margin, icon_size: icon_size
    endfor
    echo '</div>'
  endcapture
%}

{% if section.blocks.size > 0 %}
  <section
    class="sti-curved-section relative overflow-visible bg-scheme-background text-scheme-text {% if section.settings.use_gradient_background %}bg-scheme-gradient{% endif %}{% if section.settings.background_image != blank %} sti-curved-section--has-bg{% endif %}"
    data-color-scheme="{{ section.settings.color_scheme }}"
  >
    {%- if section.settings.background_image != blank -%}
      <div
        class="pointer-events-none absolute inset-0 z-0 overflow-hidden"
        aria-hidden="true"
      >
        <img
          src="{{ section.settings.background_image | image_url: width: 2400 }}"
          srcset="{{ section.settings.background_image | image_url: width: 1200 }} 1200w, {{ section.settings.background_image | image_url: width: 1800 }} 1800w, {{ section.settings.background_image | image_url: width: 2400 }} 2400w"
          sizes="100vw"
          alt=""
          class="h-full w-full object-cover"
          style="opacity: {{ section.settings.background_image_opacity | divided_by: 100.0 }};"
          loading="lazy"
          width="2400"
          height="800"
        >
      </div>
    {%- endif -%}

    {%- if section.settings.show_top_curve -%}
      <div
        class="sti-curved-section__curve sti-curved-section__curve--top{% if section.settings.top_curve_animate %} sti-curved-section__curve--animated{% endif %}"
        style="position: absolute; top: 0; left: 0; width: 100%; height: {{ section.settings.curve_height }}px; z-index: 2; overflow: visible; transform: translateY(-100%); pointer-events: none;"
      >
        <svg
          viewBox="0 0 1440 120"
          preserveAspectRatio="none"
          xmlns="http://www.w3.org/2000/svg"
          style="width: 100%; height: 100%; display: block;"
        >
          <path
            d="M0,120 L0,120 Q360,0 720,60 T1440,60 L1440,120 Z"
            fill="{{ section.settings.top_curve_color }}"
          >
            {%- if section.settings.top_curve_animate -%}
              <animate
                attributeName="d"
                dur="{{ section.settings.curve_animation_speed }}s"
                repeatCount="indefinite"
                calcMode="spline"
                keySplines="0.4 0 0.6 1; 0.4 0 0.6 1; 0.4 0 0.6 1; 0.4 0 0.6 1"
                values="M0,120 L0,120 Q360,0 720,60 T1440,60 L1440,120 Z;M0,120 L0,120 Q360,30 720,80 T1440,40 L1440,120 Z;M0,120 L0,120 Q360,90 720,20 T1440,90 L1440,120 Z;M0,120 L0,120 Q360,10 720,70 T1440,50 L1440,120 Z;M0,120 L0,120 Q360,0 720,60 T1440,60 L1440,120 Z"
              >
              </animate>
            {%- endif -%}
          </path>
        </svg>
      </div>
    {%- endif -%}

    <div class="relative z-[3]">
      {%- render 'scrolling-text', text: content, class: 'py-2.5', gap: gap %}
    </div>
  </section>

  {% style %}
    #shopify-section-{{ section.id }} {
      --icon-thickness: {{ section.settings.icon_thickness }};
    }
    {% if section.settings.background_image != blank and section.settings.background_min_height > 0 %}
      #shopify-section-{{ section.id }} .sti-curved-section--has-bg {
        min-height: {{ section.settings.background_min_height }}px;
      }
    {% endif %}
  {% endstyle %}
{% endif %}

