{%- comment -%}
  Happie SEO Store Locator
  Server-side renders all 142 retail locations as crawlable HTML + LocalBusiness
  ItemList JSON-LD schema. Works ALONGSIDE the TA Mappy widget which renders the
  visual map client-side. Without this section, Google sees an empty map page;
  with it, Google sees every store name, address, city, state, and phone -- so
  it can rank for "Happie near me", "[city] THC seltzer", and "[retailer] Happie" queries.

  Data was auto-generated 2026-06-05 from the TA Mappy CSV export
  via C:/tmp/gen_store_section.py. Re-run that script + paste the output here
  whenever you add/remove retailers.
{%- endcomment -%}

<section
  id="store-locator-seo-{{ section.id }}"
  class="store-locator-seo"
  style="
    --slseo-bg: {{ section.settings.background_color }};
    --slseo-text: {{ section.settings.text_color }};
    --slseo-heading: {{ section.settings.heading_color }};
    --slseo-accent: {{ section.settings.accent_color }};
    --slseo-card: {{ section.settings.card_color }};
    --slseo-border: {{ section.settings.border_color }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background: var(--slseo-bg);
    color: var(--slseo-text);
  "
>
  <div class="store-locator-seo__inner">
    {%- if section.settings.heading != blank -%}
      <h2 class="store-locator-seo__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}
    {%- if section.settings.subheading != blank -%}
      <p class="store-locator-seo__subheading">{{ section.settings.subheading }}</p>
    {%- endif -%}

    {%- comment -%} === SSR STORE LIST (auto-generated 2026-06-25 from TA Mappy CSV; 161 active retail locations) === {%- endcomment -%}
