<style>
  .store-locator-seo { width: 100%; }
  .store-locator-seo__inner { max-width: 1200px; margin: 0 auto; padding: 0 24px; }
  .store-locator-seo__heading {
    font-family: 'Poppins', sans-serif;
    font-size: clamp(28px, 4vw, 42px);
    font-weight: 700;
    color: var(--slseo-heading);
    text-align: center;
    margin: 0 0 12px;
  }
  .store-locator-seo__subheading {
    font-size: 17px;
    color: var(--slseo-text);
    opacity: 0.85;
    text-align: center;
    max-width: 720px;
    margin: 0 auto 32px;
  }
  .store-locator-seo__stats {
    display: flex; flex-wrap: wrap; justify-content: center; gap: 24px; margin: 0 0 36px;
  }
  .store-locator-seo__stat {
    text-align: center;
    padding: 16px 24px;
    background: var(--slseo-card);
    border-radius: 12px;
    border: 1px solid var(--slseo-border);
    min-width: 140px;
  }
  .store-locator-seo__stat-num {
    display: block; font-size: 32px; font-weight: 800;
    color: var(--slseo-accent); line-height: 1.1;
  }
  .store-locator-seo__stat-label {
    font-size: 13px; text-transform: uppercase; letter-spacing: 0.5px; opacity: 0.7;
  }
  .store-locator-seo__states { display: flex; flex-direction: column; gap: 20px; }
  .store-locator-seo__state {
    background: var(--slseo-card);
    border: 1px solid var(--slseo-border);
    border-radius: 16px;
    overflow: hidden;
  }
  .store-locator-seo__state-summary {
    cursor: pointer; padding: 18px 24px; list-style: none; user-select: none;
    display: flex; align-items: center; justify-content: space-between; gap: 12px;
    font-weight: 700; font-size: 18px; color: var(--slseo-heading);
  }
  .store-locator-seo__state-summary::-webkit-details-marker { display: none; }
  .store-locator-seo__state-summary::after {
    content: '+'; font-size: 22px; color: var(--slseo-accent);
    transition: transform 0.2s ease; margin-left: 12px;
  }
  .store-locator-seo__state[open] .store-locator-seo__state-summary::after { content: '-'; }
  .store-locator-seo__state-count {
    font-size: 13px; font-weight: 500;
    color: var(--slseo-text); opacity: 0.75;
    margin-left: auto; text-align: right;
  }
  .store-locator-seo__city {
    border-top: 1px solid var(--slseo-border);
    padding: 18px 24px;
  }
  .store-locator-seo__city-name {
    font-weight: 600; font-size: 16px;
    color: var(--slseo-accent); margin: 0 0 12px;
  }
  .store-locator-seo__stores {
    display: grid; gap: 12px;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  }
  .store-locator-seo__store {
    padding: 14px 16px;
    background: var(--slseo-bg);
    border: 1px solid var(--slseo-border);
    border-radius: 10px;
