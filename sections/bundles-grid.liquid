{%- comment -%}
  Happie Bundles Grid
  Themed landing grid for the Bundles page. Renders the curated bundle line-up
  as branded cards (image, name, tagline, can count, sale price). Each card
  links to its bundle product/detail page.

  Bundle data is defined inline below (parallel arrays) since bundles are
  curated packs. Update the arrays here when bundles change. Card links use
  `bundle_link_base` + handle; point this at the live bundle pages once they
  are published.
{%- endcomment -%}

{%- liquid
  assign heading = section.settings.heading | default: 'Happie Bundles'
  assign subheading = section.settings.subheading
  assign eyebrow = section.settings.eyebrow | default: 'Bundle & Save 5%'
  assign link_base = section.settings.bundle_link_base | default: '/products/'
  assign link_suffix = section.settings.bundle_link_suffix

  assign b_handle  = 'berry-vineyard-duo,cherry-citrus-kickoff,cherry-lime-chiller,citrus-grove-pack,orchard-twist,sweet-sour-party-stack' | split: ','
  assign b_name    = 'Berry Vineyard Duo,Cherry Citrus Kickoff,Cherry Lime Chiller,Citrus Grove Pack,Orchard Twist,Sweet & Sour Party Stack' | split: ','
  assign b_tag     = 'Orchard cherry and deep grape — a rich, fruit-forward pairing built to share.~Bright cherry meets zesty grapefruit — the easy starter two-pack for first-timers.~Sweet-tart cherry and crisp lime. The everyday cooler for slow afternoons.~All-citrus, all the time. Grapefruit and lime for the clean-and-crisp crowd.~Tart grapefruit twisted with mellow grape. A stock-up pack that keeps the fridge full.~Grape and lime by the case — the headline pack for parties and long weekends.' | split: '~'
  assign b_cans    = '24,16,20,24,36,48' | split: ','
  assign b_now     = '113.98,62.68,88.33,113.98,170.98,227.98' | split: ','
  assign b_was     = '119.98,65.98,92.98,119.98,179.98,239.98' | split: ','
  assign b_save    = '6.00,3.30,4.65,6.00,9.00,12.00' | split: ','
-%}

<section class="happie-bundles" style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;">
  <div class="happie-bundles__inner">
    <div class="happie-bundles__head">
      {%- if eyebrow != blank -%}<span class="happie-bundles__eyebrow">{{ eyebrow }}</span>{%- endif -%}
      <h1 class="happie-bundles__title">{{ heading }}</h1>
      {%- if subheading != blank -%}<p class="happie-bundles__sub">{{ subheading }}</p>{%- endif -%}
    </div>

    <div class="happie-bundles__grid">
      {%- for handle in b_handle -%}
        {%- assign i = forloop.index0 -%}
        {%- assign img = 'bundle-' | append: handle | append: '.webp' -%}
        {%- assign url = link_base | append: handle | append: link_suffix -%}
        <a class="happie-bundle-card" href="{{ url }}">
          <div class="happie-bundle-card__media">
            <span class="happie-bundle-card__cans">{{ b_cans[i] }} cans</span>
            <img src="{{ img | asset_url }}" alt="{{ b_name[i] | escape }} bundle" width="560" height="700" loading="lazy">
          </div>
          <div class="happie-bundle-card__body">
            <h3 class="happie-bundle-card__name">{{ b_name[i] }}</h3>
            <p class="happie-bundle-card__tag">{{ b_tag[i] }}</p>
            <div class="happie-bundle-card__priceline">
              <span class="happie-bundle-card__now">${{ b_now[i] }}</span>
              <span class="happie-bundle-card__was">${{ b_was[i] }}</span>
              <span class="happie-bundle-card__save">Save ${{ b_save[i] }}</span>
            </div>
            <span class="happie-bundle-card__cta">Shop bundle
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </span>
          </div>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
  .happie-bundles{background:{{ section.settings.background_color }};font-family:'Poppins',system-ui,-apple-system,sans-serif;}
  .happie-bundles__inner{max-width:1180px;margin:0 auto;padding:0 24px;}
  .happie-bundles__head{text-align:center;max-width:760px;margin:0 auto 40px;}
  .happie-bundles__eyebrow{display:inline-block;font-size:12px;letter-spacing:.14em;text-transform:uppercase;font-weight:700;color:#50B2BD;background:#fff;padding:7px 16px;border-radius:999px;margin-bottom:16px;box-shadow:0 2px 10px rgba(0,0,0,.06);}
  .happie-bundles__title{font-size:clamp(30px,5vw,46px);font-weight:800;color:#962F80;margin:0 0 12px;line-height:1.1;}
  .happie-bundles__sub{font-size:17px;line-height:1.7;color:#4a4a4a;margin:0;}
  .happie-bundles__grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:26px;}
  .happie-bundle-card{display:flex;flex-direction:column;background:#fff;border-radius:22px;overflow:hidden;text-decoration:none;border:1px solid rgba(150,47,128,.08);box-shadow:0 8px 26px rgba(150,47,128,.08);transition:transform .22s ease,box-shadow .22s ease;}
  .happie-bundle-card:hover{transform:translateY(-6px);box-shadow:0 18px 40px rgba(150,47,128,.16);}
  .happie-bundle-card__media{position:relative;aspect-ratio:4/5;background:linear-gradient(150deg,#ffffff 0%,#FBE7F3 100%);overflow:hidden;}
  .happie-bundle-card__media img{width:100%;height:100%;object-fit:contain;padding:18px;transition:transform .4s ease;}
  .happie-bundle-card:hover .happie-bundle-card__media img{transform:scale(1.05);}
  .happie-bundle-card__cans{position:absolute;top:14px;left:14px;z-index:1;font-size:12px;font-weight:700;color:#fff;background:#962F80;padding:6px 12px;border-radius:999px;letter-spacing:.02em;}
  .happie-bundle-card__body{padding:20px 22px 24px;display:flex;flex-direction:column;flex:1;}
  .happie-bundle-card__name{font-size:20px;font-weight:800;color:#1a1a1a;margin:0 0 6px;}
  .happie-bundle-card__tag{font-size:13.5px;line-height:1.55;color:#666;margin:0 0 16px;flex:1;}
  .happie-bundle-card__priceline{display:flex;align-items:center;gap:10px;flex-wrap:wrap;margin-bottom:16px;}
  .happie-bundle-card__now{font-size:20px;font-weight:800;color:#962F80;}
  .happie-bundle-card__was{font-size:14px;color:#aaa;text-decoration:line-through;}
  .happie-bundle-card__save{font-size:12px;font-weight:700;color:#2e8b6f;background:#E7F6EF;padding:4px 10px;border-radius:999px;}
  .happie-bundle-card__cta{display:inline-flex;align-items:center;gap:7px;align-self:flex-start;background:#50B2BD;color:#fff;font-size:14px;font-weight:700;padding:11px 20px;border-radius:999px;transition:background-color .2s ease,gap .2s ease;}
  .happie-bundle-card:hover .happie-bundle-card__cta{background:#3f9aa4;gap:11px;}
  @media(max-width:600px){.happie-bundles__grid{grid-template-columns:1fr;}.happie-bundles__inner{padding:0 16px;}}
</style>

{% schema %}
{
  "name": "Bundles Grid",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow pill", "default": "Bundle & Save 5%" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Happie Bundles" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Curated multi-packs of our best-selling THC seltzers — mix your favorite flavors and save 5% on every bundle." },
    { "type": "header", "content": "Card links" },
    { "type": "text", "id": "bundle_link_base", "label": "Bundle link base URL", "info": "Each card links to this base + the bundle handle (+ suffix). Point at the live bundle pages once published.", "default": "/products/" },
    { "type": "text", "id": "bundle_link_suffix", "label": "Link suffix" },
    { "type": "header", "content": "Appearance" },
    { "type": "color", "id": "background_color", "label": "Background", "default": "#ffffff" },
    { "type": "range", "id": "padding_top", "label": "Top padding", "min": 0, "max": 150, "step": 5, "unit": "px", "default": 65 },
    { "type": "range", "id": "padding_bottom", "label": "Bottom padding", "min": 0, "max": 150, "step": 5, "unit": "px", "default": 70 }
  ],
  "presets": [ { "name": "Bundles Grid" } ]
}
{% endschema %}
