{%- comment -%} GEO: Organization schema fires on ALL pages for AI search visibility; WebSite+SearchAction stays homepage-only {%- endcomment -%}
{%- liquid
  assign geo_org_logo_media = nil
  if shop.brand.metafields.settings.logo != blank
    assign geo_org_logo_media = shop.brand.metafields.settings.logo.value
  elsif shop.brand != blank and shop.brand.logo != blank
    assign geo_org_logo_media = shop.brand.logo
  endif
  assign geo_org_logo_url = nil
  assign geo_org_logo_w = 600
  assign geo_org_logo_h = 200
  if geo_org_logo_media != blank
    assign geo_org_logo_url = geo_org_logo_media | image_url: width: 600
    if geo_org_logo_url != blank
      unless geo_org_logo_url contains 'http'
        assign geo_org_logo_url = geo_org_logo_url | prepend: 'https:'
      endunless
    endif
    assign geo_org_logo_w = geo_org_logo_media.width | default: 600
    assign geo_org_logo_h = geo_org_logo_media.height | default: 200
    if geo_org_logo_media.width != blank and geo_org_logo_media.height != blank and geo_org_logo_media.width > 600
      assign geo_org_logo_h = geo_org_logo_media.height | times: 600 | divided_by: geo_org_logo_media.width
      assign geo_org_logo_w = 600
    endif
  else
    assign geo_org_logo_url = 'happie-logo.png' | file_url
    if geo_org_logo_url != blank
      unless geo_org_logo_url contains 'http'
        assign geo_org_logo_url = geo_org_logo_url | prepend: 'https:'
      endunless
    endif
  endif
-%}
