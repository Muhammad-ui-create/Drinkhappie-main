{% render 'happie-article-link-fix' %}

</head>

  {%- liquid
    assign body_classes = ''
    if template == 'product.updated-pdp'
      assign body_classes = 'updated-pdp '
    endif
    assign body_classes = body_classes | append: 'template-' | append: template.name
    if template.suffix != blank
      assign body_classes = body_classes | append: ' template-' | append: template.name | append: '-' | append: template.suffix | handle
    endif
  -%}
  <body data-color-scheme="scheme1" class="{{ body_classes | strip }}">
    {%- if settings.show_on_sale_badge -%}
      {%- render 'static-sticker-defs', shape: settings.on_sale_badge_shape, id: 'on-sale' -%}
    {%- endif -%}
    {%- if settings.show_sold_out_badge -%}
      {%- render 'static-sticker-defs', shape: settings.sold_out_badge_shape, id: 'sold-out' -%}
    {%- endif -%}
    {%- render 'static-sticker-defs', shape: settings.metafield_badge_shape, id: 'metafield-badge' -%}

    <a class="skip-link" href="#MainContent">
      {{- 'general.accessibility.skip_to_content' | t -}}
    </a>
    {%- sections 'header-group' -%}
    {% render 'header-group-support' %}
    <main id="MainContent" class="overflow-hidden">
      {{ content_for_layout }}
    </main>

    {%- sections 'footer-group' -%}
    {%- sections 'overlay-group' -%}

    <div
      id="screenreader-announce"
      class="sr-only"
      aria-live="polite"
      role="status"
    ></div>

    <ul hidden>
      <li id="a11y-refresh-page-message">
        {{ 'general.accessibility.refresh_page' | t }}
      </li>
      <li id="a11y-selection-message">
        {{ 'general.accessibility.selection_help' | t }}
      </li>
    </ul>

    {% comment %} Modal containers {% endcomment %}
    {% liquid
      render 'left-drawer'
      render 'right-drawer'
      render 'modal'
      render 'popup'
    %}

    {%- if settings.cart_type == 'modal' -%}
      {% render 'drawer-cart' %}
    {%- endif -%}

    <script src="{{ 'global.bundle.js' | asset_url }}" type="module"></script>

    {%- comment -%} Happie AI Chatbot — appears on every page {%- endcomment -%}
    {% section 'happie-chatbot' %}
  </body>
</html>
