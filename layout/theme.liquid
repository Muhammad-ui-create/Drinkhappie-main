<!doctype html>
<html class="no-js" lang="{{ request.locale.iso_code }}">
  <head>
    <script async src="https://cdn.userway.org/widget.js" data-account="Qd6zudTeks"></script>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="theme-color" content="">
    <meta name="google-site-verification" content="h4ZefG7VZe4O66YZ24NCDFtNbG8KL3aETAqdvoKdsI8" />

    {%- comment -%} GEO 2026-05-08: canonical strips ?variant= on product pages and overrides duplicate collection paths to /collections/thc-drinks. Replaces single line `<link rel="canonical" href="{{ canonical_url }}">`. {%- endcomment -%}
    {%- if template.name == 'product' -%}
      <link rel="canonical" href="{{ shop.url }}{{ product.url }}">
    {%- elsif template contains 'collection' and collection.handle != blank -%}
      {%- assign happie_duplicate_collections = 'frontpage,shop-all,thc' | split: ',' -%}
      {%- if happie_duplicate_collections contains collection.handle -%}
        <link rel="canonical" href="{{ shop.url }}/collections/thc-drinks">
      {%- else -%}
        <link rel="canonical" href="{{ canonical_url }}">
      {%- endif -%}
    {%- else -%}
      <link rel="canonical" href="{{ canonical_url }}">
    {%- endif -%}
    <link rel="preconnect" href="https://cdn.shopify.com" crossorigin>

    {%- liquid
      assign main_font = settings.type_main_font
      assign main_font_bold = main_font | font_modify: 'weight', 'bold'
      assign heading_font = settings.type_heading_font
    -%}

    {%- if settings.favicon != blank -%}
      <link
        rel="icon"
        type="image/png"
        href="{{ settings.favicon | image_url: width: '32x32' }}"
      >
    {%- endif -%}

    {%- unless settings.type_header_font.system? and settings.type_body_font.system? -%}
      <link rel="preconnect" href="https://fonts.shopifycdn.com" crossorigin>
    {%- endunless -%}

    <title>
  {%- if template.name == 'index' %}
    Happie® | Best THC Seltzers & Mushroom Drinks | Buy Online
  {%- elsif template.name == 'product' %}
    {{ page_title }} | Hemp-Derived THC Drink | Happie®
  {%- elsif template.name == 'collection' %}
    {%- if collection.handle == 'thc-drinks' or collection.handle == 'thc' or collection.handle == 'frontpage' %}
      Buy THC Seltzers Online | Delta-9 Hemp Drinks 5mg & 10mg | Happie®
    {%- elsif collection.handle == 'fungi' or collection.handle == 'fungi-fusion' %}
      Fungi Fusion Mushroom Drinks | Lion's Mane, Cordyceps & Reishi | Happie®
    {%- elsif collection.handle == 'social' %}
      THC Social Seltzers | Best Alcohol Alternative | 5mg & 10mg | Happie®
    {%- elsif collection.handle == 'merch' %}
      Happie® Merch | Official Gear
    {%- else %}
      {{ collection.title }} | Happie®
    {%- endif %}
  {%- elsif template.name == 'article' %}
    {{ article.title }} | THC & Mushroom Drink Blog | Happie®
  {%- elsif template.name == 'blog' %}
    {%- if current_page > 1 %}
      {{ blog.title }} — Page {{ current_page }} | Happie® Blog
    {%- else %}
      THC Seltzer & Functional Mushroom Drink Blog | Happie®
    {%- endif %}
  {%- elsif template.name == 'page' %}
    {%- if page.handle == 'faq' %}
      FAQ — THC Drinks, Hemp Seltzers & Mushroom Beverages | Happie®
    {%- elsif page.handle == 'wholesale' %}
      Wholesale THC Seltzers & Mushroom Drinks for Retailers | Happie®
    {%- elsif page.handle == 'about-us' or page.handle == 'about-us-updated' %}
      About Happie® | California-Crafted THC & Mushroom Beverages
    {%- elsif page.handle == 'contact' %}
      Contact Us | Happie® THC Seltzers
    {%- elsif page.handle == 'subscribe-and-save' %}
      Subscribe & Save 20% on THC Seltzers | Happie®
    {%- elsif page.handle == 'coas' %}
      Lab Test Results (COAs) | Third-Party Tested | Happie®
    {%- elsif page.handle == 'shop' %}
      Shop All THC Drinks & Mushroom Beverages Online | Happie®
    {%- elsif page.handle == 'store-locator' or page.handle == 'mappy' %}
      Find THC Seltzers Near Me | Store Locator | Happie®
    {%- else %}
      {{ page.title }} | Happie®
    {%- endif %}
  {%- elsif template.name == 'search' %}
    Search{%- if search.terms %}: {{ search.terms }}{%- endif %} | Happie®
  {%- elsif template.name == 'cart' %}
    Your Cart | Happie®
  {%- elsif template.name == '404' %}
    Page Not Found | Happie®
  {%- else %}
    {{ page_title }} | Happie®
  {%- endif %}
</title>

    {%- comment -%} GEO 2026-05-08: noindex duplicate collection paths (frontpage was already in place; extended to shop-all + thc per SEO audit) {%- endcomment -%}
    {%- if template contains 'collection' and collection.handle != blank -%}
      {%- assign happie_duplicate_collections = 'frontpage,shop-all,thc' | split: ',' -%}
      {%- if happie_duplicate_collections contains collection.handle -%}
        <meta name="robots" content="noindex, follow">
      {%- endif -%}
    {%- endif -%}

    {%- if template.name == 'index' %}
  <meta name="description" content="Happie® — premium hemp-derived Delta-9 THC seltzers (5mg & 10mg) and Fungi Fusion mushroom drinks with Lion's Mane, Cordyceps & Reishi. Nano-emulsified, fast-acting, zero alcohol, low calorie. The best THC seltzer brand — better than Brez, Cann & Wynk. Ships to 40+ states. Subscribe & save 20%.">
{%- elsif template.name == 'product' %}
  <meta name="description" content="{{ product.title }} by Happie® — {{ product.description | strip_html | truncate: 80 }} Premium hemp-derived THC drink, nano-emulsified for fast onset. Low calorie, vegan, gluten-free. Shop online with free shipping.">
{%- elsif template.name == 'collection' %}
  {%- if collection.handle == 'thc-drinks' or collection.handle == 'thc' or collection.handle == 'frontpage' %}
    <meta name="description" content="Buy the best Delta-9 THC seltzers online. Happie hemp-derived THC drinks in 5mg & 10mg — 7 fruit flavors, nano-emulsified fast-acting formula. Zero alcohol, zero hangover, 30 calories. Better than Brez, Cann, Wynk & Cycling Frog. Free shipping on $50+.">
  {%- elsif collection.handle == 'fungi' or collection.handle == 'fungi-fusion' %}
    <meta name="description" content="Fungi Fusion functional mushroom drinks — Lion's Mane 900mg, Cordyceps 700mg & Reishi 400mg per can. Zero THC, zero caffeine, zero sugar. Best mushroom beverage for focus, energy & calm. Ocean minerals for hydration. Ships nationwide.">
  {%- elsif collection.handle == 'social' %}
    <meta name="description" content="Happie Social THC Seltzers — 5mg and 10mg hemp-derived Delta-9 THC drinks perfect for parties, social gatherings & relaxation. The best alcohol alternative. Zero hangover, low calorie, vegan.">
  {%- elsif collection.description != blank %}
    <meta name="description" content="{{ collection.description | strip_html | truncate: 155 }}">
  {%- else %}
    <meta name="description" content="{{ page_description | default: shop.description | truncate: 155 }}">
  {%- endif %}
{%- elsif template.name == 'page' %}
  {%- if page.handle == 'faq' %}
    <meta name="description" content="Happie FAQ — everything about hemp-derived THC drinks, Delta-9 seltzers, functional mushroom beverages, dosing, shipping states, legality & how Happie compares to Brez, Cann, Wynk & Cycling Frog.">
  {%- elsif page.handle == 'about-us' or page.handle == 'about-us-updated' %}
    <meta name="description" content="About Happie® — California-crafted functional beverages by founder Pete Olander. Premium THC seltzers and Fungi Fusion mushroom drinks. Plant-powered happiness since 2019.">
  {%- elsif page.handle == 'wholesale' %}
    <meta name="description" content="Wholesale Happie THC seltzers and mushroom drinks for retailers, bars, restaurants & dispensaries. Premium hemp-derived beverages with competitive margins. Apply today.">
  {%- elsif page_description != blank %}
    <meta name="description" content="{{ page_description | truncate: 155 }}">
  {%- else %}
    <meta name="description" content="{{ shop.description | truncate: 155 }}">
  {%- endif %}
{%- elsif page_description != blank %}
  <meta name="description" content="{{ page_description | truncate: 155 }}">
{%- else %}
  <meta name="description" content="{{ shop.description | truncate: 155 }}">
{%- endif %}

    {%- render 'meta-tags' -%}

